{% from "govuk/components/button/macro.njk" import govukButton %}
{% extends 'layouts/page.njk' %}

{% block content %}
    <div class="govuk-grid-row" role="main">
      <div class="govuk-grid-column-two-thirds">
        <div class="govuk-panel govuk-panel--confirmation">
          <h1 class="govuk-panel__title">
            {{ panelTitle }}
          </h1>
          <div class="govuk-panel__body">
            The start date for this agreement is<br/>
            {{ agreement.payment.agreementStartDate | formatDate('d MMMM yyyy') }}
          </div>
        </div>
        <div class="govuk-panel__body">
          <p class="govuk-body">Your agreement number is {{ agreement.agreementNumber }}.</p>

          {% if showConsentSection %}
            <h2 class="govuk-heading-m">You must get consent to do your actions</h2>

            {% if consentVariant === 'both' %}
              <p class="govuk-body">You are applying for actions on land that's a site of special scientific interest (SSSI) and land with historic or archaeological features.</p>
            {% elif consentVariant === 'sssi' %}
              <p class="govuk-body">You are applying for actions on land that's a site of special scientific interest (SSSI).</p>
            {% elif consentVariant === 'hefer' %}
              <p class="govuk-body">You are applying for actions on land with historic or archaeological features.</p>
            {% endif %}

            <p class="govuk-body">Before starting your actions, you must get:</p>

            <ul class="govuk-list govuk-list--bullet">
              {% if hasHeferConsent %}
                <li><a href="https://grants-ui.dev.cdp-int.defra.cloud/farm-payments/fptt-information#sec-5-check-if-your-land-is-eligible-for-FPTT-actions" class="govuk-link">a Historic Environment Farm Environment Record (HEFER)</a> from Historic England</li>
              {% endif %}
              {% if hasSssiConsent %}
                <li><a href="https://grants-ui.dev.cdp-int.defra.cloud/farm-payments/fptt-information#sec-10-get-all-necessary-regulatory-consents-permissions-and-licences-in-place" class="govuk-link">SSSI consent</a> from Natural England</li>
              {% endif %}
            </ul>
          {% endif %}

          <h2 class="govuk-heading-m">What you've agreed</h2>
          <p class="govuk-body">You can view:</p>

          <ul class="govuk-list govuk-list--bullet">
            <li>your <a href="{{ buildUrl(baseUrl, agreement.agreementNumber) }}" class="govuk-link">agreement document</a></li>
            <li>the <a href="{{ buildUrl(serviceUrl, 'farm-payments/terms-and-conditions') }}" class="govuk-link" rel="noopener noreferrer" target="_blank">Farm payments technical test terms and conditions (opens in a new tab)</a></li>
          </ul>

          <p class="govuk-body">To check what you must do to get paid for your selected actions, read:</p>

          <ul class="govuk-list govuk-list--bullet">
            <li>the <a href="{{ buildUrl(serviceUrl, 'farm-payments/fptt-information') }}" class="govuk-link" rel="noopener noreferrer" target="_blank">Farm payments technical test information (opens in a new tab)</a></li>
            <li>the <a href="{{ buildUrl(serviceUrl, 'farm-payments/fptt-actions') }}" class="govuk-link" rel="noopener noreferrer" target="_blank">Farm payments technical test actions (opens in a new tab)</a></li>
          </ul>

          {% if nearestQuarterlyPaymentDate %}
            <p class="govuk-body">You will receive your first payment for these actions in {{ nearestQuarterlyPaymentDate }}.</p>
          {% endif %}
        </div>

        {% include "partials/help/help.njk" %}
      </div>
    </div>
{% endblock %}
